    </resultMap>
    <sql id="selectVmsOrderVo">select oid, batch_no, template_oid, voucher_name, vendor_oid, vendor_name, quantity, price, spec, amount, express_no, express_time, actual_claim_qty, claim_start_no, claim_end_no, claim_status, claim_remark, attach_url, order_status, branch_org_id from vms_order</sql>
    <select id="selectVmsOrderList" parameterType="VmsOrder" resultMap="VmsOrderResult">
        select o.oid, o.batch_no, o.template_oid, o.voucher_name, o.vendor_oid, o.vendor_name,
            o.quantity, o.price, o.spec, o.amount, o.express_no, o.express_time,
            o.actual_claim_qty, o.claim_start_no, o.claim_end_no, o.claim_status,
            o.claim_remark, o.attach_url, o.order_status, o.branch_org_id,
            sd.dept_name as branch_org_name
        from vms_order o
        left join sys_dept sd on o.branch_org_id = sd.dept_code
        <where>
            <if test="batchNo != null and batchNo != ''"> and batch_no = #{batchNo}</if>
            <if test="templateOid != null"> and template_oid = #{templateOid}</if>
            <if test="voucherName != null and voucherName != ''"> and voucher_name = #{voucherName}</if>
            <if test="vendorOid != null"> and vendor_oid = #{vendorOid}</if>
            <if test="vendorName != null and vendorName != ''"> and vendor_name = #{vendorName}</if>
            <if test="quantity != null"> and quantity = #{quantity}</if>
            <if test="price != null"> and price = #{price}</if>
            <if test="spec != null and spec != ''"> and spec = #{spec}</if>
            <if test="amount != null"> and amount = #{amount}</if>
            <if test="expressNo != null and expressNo != ''"> and express_no = #{expressNo}</if>
            <if test="expressTime != null"> and express_time = #{expressTime}</if>
            <if test="actualClaimQty != null"> and actual_claim_qty = #{actualClaimQty}</if>
            <if test="claimStartNo != null and claimStartNo != ''"> and claim_start_no = #{claimStartNo}</if>
            <if test="claimEndNo != null and claimEndNo != ''"> and claim_end_no = #{claimEndNo}</if>
            <if test="claimStatus != null and claimStatus != ''"> and claim_status = #{claimStatus}</if>
            <if test="claimRemark != null and claimRemark != ''"> and claim_remark = #{claimRemark}</if>
            <if test="attachUrl != null and attachUrl != ''"> and attach_url = #{attachUrl}</if>
            <if test="orderStatus != null and orderStatus != ''"> and order_status = #{orderStatus}</if>
            <if test="branchOrgId != null and branchOrgId != ''"> and branch_org_id = #{branchOrgId}</if>
        </where>
    </select>
    <select id="selectVmsOrderByOid" parameterType="Long" resultMap="VmsOrderResult">
        <include refid="selectVmsOrderVo"/> where oid = #{oid}
    </select>
    <insert id="insertVmsOrder" parameterType="VmsOrder" useGeneratedKeys="true" keyProperty="oid">
        insert into vms_order <trim prefix="(" suffix=")" suffixOverrides=",">
