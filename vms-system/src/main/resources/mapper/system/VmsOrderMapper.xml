            <if test="actualClaimQty != null">actual_claim_qty,</if>
            <if test="claimStartNo != null">claim_start_no,</if>
            <if test="claimEndNo != null">claim_end_no,</if>
            <if test="claimStatus != null">claim_status,</if>
            <if test="claimRemark != null">claim_remark,</if>
            <if test="attachUrl != null">attach_url,</if>
            <if test="orderStatus != null">order_status,</if>
            <if test="branchOrgId != null">branch_org_id,</if>
        </trim><trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchNo != null">#{batchNo},</if>
            <if test="templateOid != null">#{templateOid},</if>
            <if test="voucherName != null">#{voucherName},</if>
            <if test="vendorOid != null">#{vendorOid},</if>
