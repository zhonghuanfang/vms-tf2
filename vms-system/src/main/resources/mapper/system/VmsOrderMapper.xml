            <if test="orderStatus != null">order_status = #{orderStatus},</if>
            <if test="branchOrgId != null">branch_org_id = #{branchOrgId},</if>
        </trim> where oid = #{oid}
    </update>
    <delete id="deleteVmsOrderByOid" parameterType="Long">delete from vms_order where oid = #{oid}</delete>
    <delete id="deleteVmsOrderByOids" parameterType="String">
        delete from vms_order where oid in
        <foreach item="oid" collection="array" open="(" separator="," close=")">#{oid}</foreach>
    </delete>
</mapper>
