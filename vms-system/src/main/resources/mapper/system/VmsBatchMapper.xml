<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.tf.vms.system.mapper.VmsBatchMapper">
    <resultMap type="VmsBatch" id="VmsBatchResult">
        <result property="oid"    column="oid"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="batchName"    column="batch_name"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="batchDesc"    column="batch_desc"    />
        <result property="status"    column="status"    />
        <result property="statusRemark"    column="status_remark"    />
        <result property="createdBy"    column="created_by"    />
        <result property="version"    column="version"    />
        <result property="headOrgId"    column="head_org_id"    />
    </resultMap>
    <sql id="selectVmsBatchVo">select oid, batch_no, batch_name, start_time, end_time, batch_desc, status, status_remark, created_by, version, head_org_id from vms_batch</sql>
    <select id="selectVmsBatchList" parameterType="VmsBatch" resultMap="VmsBatchResult">
        <include refid="selectVmsBatchVo"/><where>
            <if test="batchNo != null and batchNo != ''"> and batch_no = #{batchNo}</if>
            <if test="batchName != null and batchName != ''"> and batch_name = #{batchName}</if>
            <if test="startTime != null"> and start_time = #{startTime}</if>
            <if test="endTime != null"> and end_time = #{endTime}</if>
            <if test="batchDesc != null and batchDesc != ''"> and batch_desc = #{batchDesc}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
            <if test="statusRemark != null and statusRemark != ''"> and status_remark = #{statusRemark}</if>
            <if test="createdBy != null and createdBy != ''"> and created_by = #{createdBy}</if>
            <if test="version != null"> and version = #{version}</if>
            <if test="headOrgId != null and headOrgId != ''"> and head_org_id = #{headOrgId}</if>
        </where>
    </select>
    <select id="selectVmsBatchByOid" parameterType="Long" resultMap="VmsBatchResult">
        <include refid="selectVmsBatchVo"/> where oid = #{oid}
    </select>
    <insert id="insertVmsBatch" parameterType="VmsBatch" useGeneratedKeys="true" keyProperty="oid">
        insert into vms_batch <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="batchNo != null">batch_no,</if>
            <if test="batchName != null">batch_name,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="batchDesc != null">batch_desc,</if>
            <if test="status != null">status,</if>
            <if test="statusRemark != null">status_remark,</if>
            <if test="createdBy != null">created_by,</if>
            <if test="version != null">version,</if>
            <if test="headOrgId != null">head_org_id,</if>
        </trim><trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="batchNo != null">#{batchNo},</if>
            <if test="batchName != null">#{batchName},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="batchDesc != null">#{batchDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="statusRemark != null">#{statusRemark},</if>
            <if test="createdBy != null">#{createdBy},</if>
            <if test="version != null">#{version},</if>
            <if test="headOrgId != null">#{headOrgId},</if>
        </trim>
    </insert>
    <update id="updateVmsBatch" parameterType="VmsBatch">
        update vms_batch <trim prefix="SET" suffixOverrides=",">
            <if test="batchNo != null">batch_no = #{batchNo},</if>
            <if test="batchName != null">batch_name = #{batchName},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="batchDesc != null">batch_desc = #{batchDesc},</if>
            <if test="status != null">status = #{status},</if>
            <if test="statusRemark != null">status_remark = #{statusRemark},</if>
            <if test="createdBy != null">created_by = #{createdBy},</if>
            <if test="version != null">version = #{version},</if>
            <if test="headOrgId != null">head_org_id = #{headOrgId},</if>
        </trim> where oid = #{oid}
    </update>
    <delete id="deleteVmsBatchByOid" parameterType="Long">delete from vms_batch where oid = #{oid}</delete>
    <delete id="deleteVmsBatchByOids" parameterType="String">
        delete from vms_batch where oid in
        <foreach item="oid" collection="array" open="(" separator="," close=")">#{oid}</foreach>
    </delete>
</mapper>
